{
  "name": "Ham Radio License Study App",
  "short_name": "Ham Study",
  "description": "Canadian amateur radio license preparation with practice exams and Morse code training",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#4f93e0",
  "orientation": "any",
  "icons": [
    {
      "src": "/icons/icon.svg",
      "sizes": "72x72 96x96 128x128 144x144 152x152 192x192 384x384 512x512",
      "type": "image/svg+xml",
      "purpose": "any"
    },
    {
      "src": "/icons/maskable-icon.svg",
      "sizes": "196x196",
      "type": "image/svg+xml",
      "purpose": "maskable"
    },
    {
      "src": "/generated-icon.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],
  "shortcuts": [
    {
      "name": "Practice Exam",
      "short_name": "Exam",
      "description": "Take practice exam",
      "url": "/learning",
      "icons": [{ "src": "/icons/frequencies.svg", "sizes": "96x96", "type": "image/svg+xml" }]
    },
    {
      "name": "Morse Code",
      "short_name": "Morse",
      "description": "Practice Morse code",
      "url": "/morse-code",
      "icons": [{ "src": "/icons/logbook.svg", "sizes": "96x96", "type": "image/svg+xml" }]
    },
    {
      "name": "Study Guide",
      "short_name": "Study",
      "description": "Reference materials",
      "url": "/reference",
      "icons": [{ "src": "/icons/map.svg", "sizes": "96x96", "type": "image/svg+xml" }]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "categories": ["utilities", "communication", "productivity"],
  "lang": "en-US",
  "dir": "ltr",
  "scope": "/",
  "iarc_rating_id": "",
  "share_target": {
    "action": "/share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "image",
          "accept": ["image/*"]
        },
        {
          "name": "audio",
          "accept": ["audio/*"]
        }
      ]
    }
  },
  "screenshots": [
    {
      "src": "/screenshots/screen1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Home Screen"
    },
    {
      "src": "/screenshots/screen2.png",
      "sizes": "1280x720",
      "type": "image/png", 
      "platform": "wide",
      "label": "Logbook"
    }
  ]
}